# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Core Dependencies (Blocks root AND nested folders completely)
node_modules/
**/node_modules/
vendor/
**/vendor/
.pnp
.pnp.js

# Framework Compilations & Builds
.next/
**/.next/
out/
build/
dist/

# Local Environment & Secrets
.env
.env.*
!.env.example
*.pem

# MAMP / SQLite / Local Backups
*.sqlite
*.zip
*.tar.gz
.DS_Store

# Testing & Logs
coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Vercel & TypeScript Tracking
.vercel
*.tsbuildinfo
next-env.d.ts